# =============================================================
# BSSP Agentes — Variáveis de Ambiente
# Copie para .env e preencha com os valores reais
# =============================================================

# --- RD Station Marketing API ---
# OPÇÃO 1: API Key (recomendado — mais simples)
# Obtém em: RD Station → Conta → Integrações → Chaves de API → Token Privado
RDSTATION_API_KEY=seu_token_privado_aqui

# OPÇÃO 2: OAuth (alternativo — só se precisar de app na App Store)
# RDSTATION_CLIENT_ID=
# RDSTATION_CLIENT_SECRET=
# RDSTATION_REFRESH_TOKEN=

# Plano do RD Station (afeta rate limits)
RDSTATION_PLAN=pro  # light, basic, pro ou advanced

# --- Webhook Security ---
# Chave para validar webhooks recebidos do RD Station
RDSTATION_WEBHOOK_SECRET=uma_chave_secreta_forte

# --- Database ---
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/bssp_agentes

# --- Redis (Celery broker) ---
REDIS_URL=redis://localhost:6379/0

# --- SendGrid (Squad 3 — Comunicação por e-mail) ---
# API key gerada em: SendGrid → Settings → API Keys (com escopo Mail Send)
SENDGRID_API_KEY=
# E-mail remetente — domínio precisa estar verificado (DKIM/SPF/DMARC) na SendGrid
SENDGRID_FROM_EMAIL=no-reply@bssp.com.br
SENDGRID_FROM_NAME=BSSP Centro Educacional
# Reply-to opcional (caixa onde respostas chegam)
SENDGRID_REPLY_TO_EMAIL=contato@bssp.com.br
SENDGRID_REPLY_TO_NAME=Equipe BSSP
# Sandbox: true = valida payload mas NÃO envia (default seguro)
# Mudar para false após testar em produção e configurar domínio.
SENDGRID_SANDBOX_MODE=true
# Timeout das chamadas HTTP à SendGrid (segundos)
SENDGRID_TIMEOUT_S=15
# (opcional) Chave pública Ed25519 para verificar assinatura dos webhooks
# Habilitar em: SendGrid → Settings → Mail Settings → Event Webhook → Signed Event Webhook
SENDGRID_WEBHOOK_PUBLIC_KEY=

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
