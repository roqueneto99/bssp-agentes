# =========================================================
# BSSP Agentes - .gitignore
# =========================================================

# --- Segredos / env ---
.env
.env.local
.env.*.local

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Virtualenv ---
.venv/
venv/
env/

# --- IDEs ---
.vscode/
.idea/
*.swp

# --- macOS ---
.DS_Store
.~lock.*#

# --- Logs e output local ---
*.log
diagnostic_output*.txt
squad1_resultado.json
squad1_dashboard.html

# --- Arquivados (não sobem pro repo) ---
_arquivados_*/

# --- Railway / Deploy ---
.railway/

# --- Backups automáticos ---
*.bak.*
*.bak
