# ===== NextAuth =====
# URL pública do app (em desenvolvimento: http://localhost:3000)
NEXTAUTH_URL=http://localhost:3000
# Gerar com: openssl rand -base64 32
NEXTAUTH_SECRET=

# ===== Usuários =====
# Lista JSON com email, passwordHash (bcrypt), role e name (opcional).
# Gerar passwordHash com: pnpm hash "<senha>"
# Exemplo (uma linha):
# USERS_JSON=[{"email":"roque@bssp.com.br","passwordHash":"$2a$10$...","role":"admin","name":"Roque"}]
USERS_JSON=[]

# ===== Backend FastAPI =====
BACKEND_URL=https://bssp-agentes-production.up.railway.app
# Token simples para chamadas internas frontend -> backend.
BACKEND_INTERNAL_TOKEN=

# ===== Postgres (compartilhado com backend) =====
DATABASE_URL=

# ===== Telemetria (opcional) =====
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ===== Google SSO (deixar vazio na fase atual) =====
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# ALLOWED_EMAIL_DOMAIN=bssp.com.br
